# ==============================
# ResumAI environment variables
# ==============================

# --- App URLs ---
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000

# --- Database ---
DATABASE_URL=postgresql://resumai:resumai@localhost:5432/resumai
REDIS_URL=redis://localhost:6379

# --- Session / crypto ---
# generate: openssl rand -hex 32
COOKIE_SECRET=replace-with-openssl-rand-hex-32

# --- OpenAI (via proxy) ---
OPENAI_API_KEY=sk-...
# HTTPS proxy to reach OpenAI from RU infra. Format: https://user:pass@host:port
OPENAI_PROXY_URL=
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- Anthropic (final fallback, optional) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- YooKassa ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# --- Playwright fallback parser ---
PLAYWRIGHT_SERVICE_URL=http://playwright:5800

# --- Feature flags ---
LOG_LEVEL=info
RATE_LIMIT_GENERATE_PER_HOUR=20
