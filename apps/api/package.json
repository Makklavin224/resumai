    "@fastify/static": "^8.2.0",
    "@resumai/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.1.2",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.6.1",
