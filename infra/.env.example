# Production .env for infra/compose.yml — copy to .env and fill in.

# Domain (leave empty for IP-only deploy; Caddy serves plain HTTP)
RESUMAI_DOMAIN=
PUBLIC_WEB_URL=http://your-vps-ip
PUBLIC_API_URL=http://your-vps-ip

# Database
POSTGRES_PASSWORD=change-me-to-strong-random

# Session
COOKIE_SECRET=generate-with-openssl-rand-hex-32

# OpenAI via proxy (mandatory from RU infra)
OPENAI_API_KEY=sk-...
OPENAI_PROXY_URL=https://user:pass@proxy.example.com:8443
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# Optional Claude fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

LOG_LEVEL=info
RATE_LIMIT_GENERATE_PER_HOUR=20
